<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SECRET CLUB® — LA MESA NO ES PARA TODOS</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --black: #050505;
    --black2: #111111;
    --dark: #181818;
    --white: #FFFFFF;
    --silver: #C0C0C0;
    --red: #CC0000;
    --red-dark: #8B0000;
    --font-display: 'Bebas Neue', sans-serif;
    --font-body: 'Inter', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: var(--font-body);
    overflow-x: hidden;
    cursor: none;
  }

  /* CUSTOM CURSOR — crosshair style */
  #cursor {
    position: fixed;
    width: 6px; height: 6px;
    background: var(--red);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: width 0.25s, height 0.25s, background 0.25s;
  }
  #cursor-h {
    position: fixed;
    width: 20px; height: 1px;
    background: var(--red);
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%, -50%);
    transition: width 0.2s, opacity 0.2s;
    opacity: 0.7;
  }
  #cursor-v {
    position: fixed;
    width: 1px; height: 20px;
    background: var(--red);
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%, -50%);
    transition: height 0.2s, opacity 0.2s;
    opacity: 0.7;
  }
  #cursor-ring {
    position: fixed;
    width: 32px; height: 32px;
    border: 1px solid rgba(204,0,0,0.5);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9997;
    transform: translate(-50%, -50%);
    transition: transform 0.18s ease-out, width 0.3s, height 0.3s, border-color 0.3s;
  }
  body.cursor-hover #cursor { width: 10px; height: 10px; background: var(--white); }
  body.cursor-hover #cursor-ring { width: 48px; height: 48px; border-color: rgba(204,0,0,0.8); }
  body.cursor-hover #cursor-h { width: 28px; opacity: 1; background: var(--white); }
  body.cursor-hover #cursor-v { height: 28px; opacity: 1; background: var(--white); }

  /* LOADING SCREEN */
  #loader {
    position: fixed; inset: 0;
    background: var(--black);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 24px;
  }
  #loader-logo {
    font-family: var(--font-display);
    font-size: clamp(32px, 6vw, 72px);
    letter-spacing: 0.25em;
    color: var(--white);
    opacity: 0;
  }
  #loader-line {
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--red), transparent);
    transition: none;
  }
  #loader-tagline {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.35em;
    color: var(--silver);
    opacity: 0;
    text-transform: uppercase;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    padding: 28px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(to bottom, rgba(5,5,5,0.9), transparent);
    backdrop-filter: blur(0px);
    transition: backdrop-filter 0.4s, background 0.4s;
  }
  nav.scrolled {
    background: rgba(5,5,5,0.92);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 0.2em;
    color: var(--white);
    text-decoration: none;
    cursor: none;
  }
  .nav-links {
    display: flex;
    gap: 40px;
    list-style: none;
  }
  .nav-links a {
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--silver);
    text-decoration: none;
    transition: color 0.3s;
    cursor: none;
  }
  .nav-links a:hover { color: var(--white); }
  .nav-ig {
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--white);
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.25);
    padding: 10px 20px;
    transition: border-color 0.3s, background 0.3s;
    cursor: none;
    text-transform: uppercase;
  }
  .nav-ig:hover { border-color: var(--red); background: rgba(204,0,0,0.1); }

  /* HERO */
  #hero {
    height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      linear-gradient(to bottom, rgba(5,5,5,0.3) 0%, rgba(5,5,5,0.6) 50%, rgba(5,5,5,0.95) 100%),
      radial-gradient(ellipse at 60% 40%, rgba(204,0,0,0.14) 0%, transparent 65%);
    z-index: 1;
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 80px 80px;
    z-index: 0;
    opacity: 0.5;
  }
  .hero-visual {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 70% 30%, rgba(139,0,0,0.2) 0%, transparent 50%),
      radial-gradient(ellipse at 30% 70%, rgba(204,0,0,0.1) 0%, transparent 45%),
      linear-gradient(145deg, #0a0a0a 0%, #050505 40%, #120808 100%);
    z-index: 0;
  }
  .suit-float {
    position: absolute;
    font-size: 200px;
    opacity: 0.04;
    color: var(--white);
    pointer-events: none;
    z-index: 0;
    user-select: none;
  }
  .suit-float.s1 { top: 10%; left: 5%; font-size: 300px; }
  .suit-float.s2 { bottom: 5%; right: 3%; font-size: 250px; opacity: 0.03; }
  .suit-float.s3 { top: 40%; left: 50%; font-size: 180px; opacity: 0.025; }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 900px;
    padding: 0 24px;
  }
  .hero-eyebrow {
    font-size: 11px;
    letter-spacing: 0.45em;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 24px;
    opacity: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }
  .hero-eyebrow::before, .hero-eyebrow::after {
    content: '';
    width: 40px; height: 1px;
    background: var(--red);
    display: block;
  }
  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(52px, 9vw, 130px);
    line-height: 0.9;
    letter-spacing: 0.04em;
    color: var(--white);
    opacity: 0;
    margin-bottom: 20px;
  }
  .hero-h1 span { color: var(--red); }
  .hero-tagline {
    font-size: clamp(11px, 1.5vw, 13px);
    letter-spacing: 0.5em;
    color: var(--silver);
    text-transform: uppercase;
    opacity: 0;
    margin-bottom: 12px;
  }
  .hero-divider {
    width: 1px; height: 40px;
    background: linear-gradient(to bottom, transparent, var(--silver), transparent);
    margin: 28px auto;
    opacity: 0;
  }
  .hero-desc {
    font-size: 14px;
    line-height: 1.8;
    color: rgba(255,255,255,0.5);
    max-width: 480px;
    margin: 0 auto 40px;
    opacity: 0;
    font-weight: 300;
    letter-spacing: 0.04em;
  }
  .hero-btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
  }
  .btn-primary {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--black);
    background: var(--white);
    padding: 16px 36px;
    text-decoration: none;
    transition: background 0.3s, color 0.3s, transform 0.2s;
    cursor: none;
    font-weight: 500;
  }
  .btn-primary:hover { background: var(--red); color: var(--white); transform: translateY(-2px); }
  .btn-ghost {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--white);
    background: transparent;
    border: 1px solid rgba(255,255,255,0.3);
    padding: 16px 36px;
    text-decoration: none;
    transition: border-color 0.3s, background 0.3s, transform 0.2s;
    cursor: none;
    font-weight: 400;
  }
  .btn-ghost:hover { border-color: var(--red); background: rgba(204,0,0,0.12); transform: translateY(-2px); }
  .hero-scroll {
    position: absolute;
    bottom: 40px; left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
  }
  .scroll-label {
    font-size: 9px;
    letter-spacing: 0.4em;
    color: var(--silver);
    text-transform: uppercase;
  }
  .scroll-line {
    width: 1px; height: 48px;
    background: linear-gradient(to bottom, var(--silver), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  /* TICKER */
  #ticker {
    background: var(--red);
    overflow: hidden;
    padding: 14px 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .ticker-track {
    display: flex;
    white-space: nowrap;
    animation: tickerAnim 28s linear infinite;
    width: max-content;
  }
  .ticker-item {
    font-size: 11px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--white);
    padding: 0 48px;
    font-weight: 500;
  }
  @keyframes tickerAnim {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* SECTIONS */
  section { padding: 120px 0; }
  .container { max-width: 1320px; margin: 0 auto; padding: 0 48px; }

  .section-eyebrow {
    font-size: 10px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .section-eyebrow::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,0.08);
  }

  /* COLLECTIONS */
  #collections { background: var(--black2); }
  .collections-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: end;
    margin-bottom: 72px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(48px, 7vw, 96px);
    line-height: 0.95;
    letter-spacing: 0.03em;
  }
  .collections-subtitle {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    line-height: 1.8;
    font-weight: 300;
    letter-spacing: 0.04em;
    max-width: 340px;
    margin-left: auto;
  }
  .collections-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
  }
  .collection-card {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    cursor: none;
    background: var(--dark);
  }
  .collection-card:first-child { grid-column: span 2; aspect-ratio: 6/5; }
  .card-visual {
    position: absolute; inset: 0;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .collection-card:hover .card-visual { transform: scale(1.06); }

  .card-visual.cv1 {
    background: radial-gradient(ellipse at 40% 30%, rgba(139,0,0,0.55) 0%, rgba(5,5,5,0.9) 60%),
    linear-gradient(160deg, #120808 0%, #050505 100%);
  }
  .card-visual.cv2 {
    background: radial-gradient(ellipse at 60% 60%, rgba(204,0,0,0.35) 0%, rgba(5,5,5,0.95) 60%),
    linear-gradient(200deg, #0a0a0a 0%, #150505 100%);
  }
  .card-visual.cv3 {
    background: radial-gradient(ellipse at 50% 20%, rgba(192,192,192,0.15) 0%, rgba(5,5,5,0.95) 60%),
    linear-gradient(180deg, #0d0d0d 0%, #050505 100%);
  }
  .card-visual.cv4 {
    background: radial-gradient(ellipse at 30% 70%, rgba(139,0,0,0.45) 0%, rgba(5,5,5,0.9) 60%),
    linear-gradient(120deg, #120505 0%, #050505 100%);
  }
  .card-suit {
    position: absolute;
    bottom: 60px; right: 20px;
    font-size: 80px;
    opacity: 0.08;
    color: var(--white);
    transition: opacity 0.4s;
    z-index: 1;
    user-select: none;
  }
  .collection-card:hover .card-suit { opacity: 0.15; }
  .card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(5,5,5,0.92) 0%, rgba(5,5,5,0.2) 50%, transparent 100%);
    z-index: 2;
    transition: background 0.4s;
  }
  .collection-card:hover .card-overlay {
    background: linear-gradient(to top, rgba(5,5,5,0.96) 0%, rgba(5,5,5,0.4) 60%, transparent 100%);
  }
  .card-info {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 32px 28px;
    z-index: 3;
  }
  .card-number {
    font-size: 9px;
    letter-spacing: 0.4em;
    color: var(--red);
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .card-title {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.5vw, 30px);
    letter-spacing: 0.06em;
    color: var(--white);
    margin-bottom: 10px;
    line-height: 1;
  }
  .card-desc {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    line-height: 1.7;
    letter-spacing: 0.03em;
    max-width: 280px;
    transform: translateY(8px);
    opacity: 0;
    transition: transform 0.4s, opacity 0.4s;
    font-weight: 300;
  }
  .collection-card:hover .card-desc { transform: translateY(0); opacity: 1; }

  /* MANIFESTO */
  #manifesto {
    position: relative;
    overflow: hidden;
    background: var(--black);
    padding: 160px 0;
  }
  .manifesto-suits {
    position: absolute; inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 100px;
    pointer-events: none;
    z-index: 0;
  }
  .manifesto-suit {
    font-size: 320px;
    opacity: 0.03;
    color: var(--white);
    user-select: none;
    animation: floatSuit 8s ease-in-out infinite;
  }
  .manifesto-suit:nth-child(2) { animation-delay: -2.5s; }
  .manifesto-suit:nth-child(3) { animation-delay: -5s; }
  @keyframes floatSuit {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(3deg); }
  }
  .manifesto-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .manifesto-headline {
    font-family: var(--font-display);
    font-size: clamp(44px, 8vw, 112px);
    line-height: 0.92;
    letter-spacing: 0.02em;
    color: var(--white);
    margin-bottom: 56px;
  }
  .manifesto-headline em { color: var(--red); font-style: normal; }
  .manifesto-lines {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .manifesto-line {
    font-size: clamp(13px, 1.4vw, 16px);
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 20px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: color 0.4s;
    font-weight: 300;
  }
  .manifesto-line:first-child { border-top: 1px solid rgba(255,255,255,0.06); }
  .manifesto-line:hover { color: rgba(255,255,255,0.7); }
  .manifesto-line strong { color: var(--white); font-weight: 500; }

  /* LOOKBOOK */
  #lookbook {
    background: var(--black2);
    padding: 0;
    overflow: hidden;
  }
  .lookbook-header {
    padding: 100px 48px 72px;
    max-width: 1320px;
    margin: 0 auto;
  }
  .lookbook-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 2px;
  }
  .lb-item {
    position: relative;
    overflow: hidden;
    cursor: none;
  }
  .lb-item:first-child { grid-row: span 2; min-height: 700px; }
  .lb-item:not(:first-child) { min-height: 340px; }
  .lb-visual {
    position: absolute; inset: 0;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .lb-item:hover .lb-visual { transform: scale(1.05); }
  .lb-visual.lv1 {
    background: radial-gradient(ellipse at 50% 40%, rgba(204,0,0,0.3) 0%, #0a0808 70%),
    linear-gradient(170deg, #150505 0%, #050505 100%);
  }
  .lb-visual.lv2 {
    background: radial-gradient(ellipse at 70% 30%, rgba(192,192,192,0.12) 0%, #050505 60%),
    linear-gradient(140deg, #0d0d0d 0%, #0a0a0a 100%);
  }
  .lb-visual.lv3 {
    background: radial-gradient(ellipse at 30% 60%, rgba(139,0,0,0.4) 0%, #050505 60%),
    linear-gradient(180deg, #120505 0%, #050505 100%);
  }
  .lb-visual.lv4 {
    background: radial-gradient(ellipse at 60% 50%, rgba(204,0,0,0.2) 0%, #060606 60%),
    linear-gradient(160deg, #0a0a0a 0%, #120808 100%);
  }
  .lb-visual.lv5 {
    background: radial-gradient(ellipse at 40% 40%, rgba(192,192,192,0.08) 0%, #050505 60%),
    linear-gradient(200deg, #0f0f0f 0%, #050505 100%);
  }
  .lb-overlay {
    position: absolute; inset: 0;
    background: rgba(5,5,5,0.3);
    z-index: 1;
    transition: background 0.4s;
  }
  .lb-item:hover .lb-overlay { background: rgba(5,5,5,0.15); }
  .lb-label {
    position: absolute;
    top: 24px; left: 24px;
    font-size: 9px;
    letter-spacing: 0.4em;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    z-index: 2;
    font-weight: 500;
  }
  .lb-suit {
    position: absolute;
    bottom: 20px; right: 20px;
    font-size: 60px;
    opacity: 0.06;
    z-index: 2;
    user-select: none;
    color: var(--white);
    transition: opacity 0.4s;
  }
  .lb-item:hover .lb-suit { opacity: 0.12; }

  /* PHILOSOPHY */
  #philosophy {
    background: var(--black);
    padding: 160px 0;
    position: relative;
    overflow: hidden;
  }
  .philosophy-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 48px;
  }
  .philosophy-left .section-eyebrow { margin-bottom: 32px; }
  .philosophy-statement {
    font-family: var(--font-display);
    font-size: clamp(44px, 5.5vw, 80px);
    letter-spacing: 0.03em;
    line-height: 0.95;
    margin-bottom: 40px;
  }
  .philosophy-statement em { color: var(--red); font-style: normal; }
  .philosophy-text p {
    font-size: 14px;
    color: rgba(255,255,255,0.4);
    line-height: 1.9;
    margin-bottom: 20px;
    font-weight: 300;
    letter-spacing: 0.03em;
  }
  .philosophy-text p strong { color: rgba(255,255,255,0.8); font-weight: 500; }
  .philosophy-right {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .philosophy-visual {
    width: 100%;
    aspect-ratio: 1;
    background:
      radial-gradient(ellipse at 50% 50%, rgba(139,0,0,0.3) 0%, transparent 65%),
      linear-gradient(135deg, #120505 0%, #050505 100%);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .philosophy-center-suit {
    font-size: 180px;
    color: var(--red);
    opacity: 0.18;
    user-select: none;
    animation: floatSuit 6s ease-in-out infinite;
  }
  .philosophy-border {
    position: absolute; inset: 0;
    border: 1px solid rgba(255,255,255,0.05);
  }
  .philosophy-tag {
    position: absolute;
    bottom: -24px; right: -24px;
    background: var(--red);
    padding: 20px 28px;
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    font-weight: 500;
  }

  /* UPCOMING DROP */
  #drop {
    background: var(--black2);
    padding: 120px 0;
  }
  .drop-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 48px;
    text-align: center;
  }
  .drop-container {
    background: rgba(255,255,255,0.03);
